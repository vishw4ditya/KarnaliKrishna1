# Server Configuration
PORT=5000
NODE_ENV=production

# Database Connection (MongoDB Atlas URI)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>

# Security
JWT_SECRET=your_production_long_jwt_secret_key_here

# Initial Super Admin (Owner) Credentials Seeding (Optional)
ADMIN_EMAIL=admin@nepalbazaar.com
ADMIN_PASSWORD=your_secure_admin_password_here

# Optional Cloudinary Media Storage Credentials (local disk fallback used if left blank)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
